---
import { VisualEditing } from "@sanity/astro/visual-editing";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const canonicalURL = Astro.url;

const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";
---

<!doctype html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={canonicalURL} />

    {description && <meta name="description" content={description} />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}

    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}
    <meta name="robots" content="noindex, nofollow">
    <!-- Open Graph image -->
    {image && <meta property="og:image" content={image} />}

    <link rel="stylesheet" href="/css/style.css" />

    <title>{title}</title>
  </head>
  <body>
    <VisualEditing enabled={visualEditingEnabled} />

    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__logo" href="/" aria-label="Перша баптистська церква">
          <img class="site-header__logo-icon" src="/img/logo.png" alt="" width="67" height="75" />
          <span class="site-header__logo-text">Перша<br />баптистська<br />церква</span>
        </a>

        <nav class="site-header__nav" id="site-nav" aria-label="Основна навігація">
          <a href="#news">Новини</a>
          <a href="#about">Про церкву</a>
          <a href="#ministries">Служіння</a>
          <a href="#schedule">Розклад богослужінь</a>
          <a href="#broadcast">Трансляції</a>
          <a class="site-header__btn" href="#">Пожертви</a>
        </nav>

        <button class="menu-toggle--burger" type="button" aria-label="Відкрити меню" aria-controls="site-nav" aria-expanded="false">
          <span class="hamburger" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class="cross" aria-hidden="true">
            <span></span>
            <span></span>
          </span>
        </button>
      </div>
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="site-footer" id="contacts">
      <div class="container site-footer__bar">
        <a class="site-footer__brand" href="/">
          <img src="/img/logo-footer.png" alt="" width="47" height="53" />
          <span>Перша Баптистська Церква м. Черкаси — християнська громада,<br />що служить Богу та людям з любов'ю, вірою і надією.</span>
        </a>
        <div class="site-footer__socials" aria-label="Соціальні мережі">
          <a href="#" aria-label="Facebook"><img src="/img/soc1.png" alt="" width="17" height="32" /></a>
          <a href="#" aria-label="Instagram"><img src="/img/soc2.png" alt="" width="32" height="32" /></a>
          <a href="#" aria-label="YouTube"><img src="/img/soc3.png" alt="" width="43" height="32" /></a>
        </div>
      </div>
      <div class="container site-footer__meta">
        <p>© 2026 baptist.ck.ua</p>
        <p>Зроблено з <img src="/img/heart.png" alt="" width="28" height="25" /> любов'ю до ближнього</p>
      </div>
    </footer>

    <script type="importmap" is:inline>
      {
        "imports": {
          "swiper": "https://esm.sh/swiper@11",
          "swiper/modules": "https://esm.sh/swiper@11/modules",
          "lucide": "https://esm.sh/lucide@0.468.0"
        }
      }
    </script>
    <script src="/js/main.js" defer is:inline></script>
  </body>
</html>
